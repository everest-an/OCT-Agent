{
  "name": "awareness-claw-desktop",
  "version": "0.1.0",
  "description": "AwarenessClaw Desktop — Visual AI agent manager with persistent memory",
  "author": "edwin-hao-ai",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "npx -p typescript tsc -p tsconfig.electron.json && concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "npx -p typescript tsc -p tsconfig.electron.json && vite build",
    "build:package": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --dir",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win",
    "package:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@types/ws": "^8.18.1",
    "lucide-react": "^0.468.0",
    "npm": "^10.9.0",
    "react-force-graph-2d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "33.4.11",
    "electron-builder": "^25.1.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.2",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "market.awareness.claw",
    "productName": "AwarenessClaw",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/npm/**/*",
      "cache/**/*",
      "resources/icon.*"
    ],
    "asarUnpack": [
      "node_modules/npm/**/*"
    ],
    "extraResources": [
      { "from": "workflows", "to": "workflows", "filter": ["*.yaml", "*.yml"] }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "icon": "resources/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "createDesktopShortcut": "always",
      "shortcutName": "AwarenessClaw",
      "allowToChangeInstallationDirectory": false,
      "include": "scripts/installer.nsh"
    },
    "publish": {
      "provider": "github",
      "owner": "edwin-hao-ai",
      "repo": "AwarenessClaw"
    }
  },
  "license": "MIT"
}
